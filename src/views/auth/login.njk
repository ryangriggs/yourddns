{% extends "layouts/base.njk" %}
{% block content %}
<div class="auth-card">
  <div class="auth-header">
    <h1 class="auth-title">{{ siteName }}</h1>
    <p class="auth-subtitle">Sign in to your account</p>
  </div>

  {% if message == 'verify_email' %}
  <div class="alert alert-info">Check your email to verify your account before signing in.</div>
  {% elif message == 'email_verified' %}
  <div class="alert alert-success">Email verified! You can now sign in.</div>
  {% elif message == 'password_reset' %}
  <div class="alert alert-success">Password updated. Sign in with your new password.</div>
  {% elif message == 'verify_resent' %}
  <div class="alert alert-info">Verification email resent.</div>
  {% endif %}

  {% if error == 'invalid' %}
  <div class="alert alert-error">Invalid email or password.</div>
  {% elif error == 'disabled' %}
  <div class="alert alert-error">Your account has been disabled.</div>
  {% elif error == 'blocked' %}
  <div class="alert alert-error">Access denied.</div>
  {% elif error == 'unverified' %}
  <div class="alert alert-warning">
    Please verify your email first.
    <a href="/auth/resend-verification?email={{ email | urlencode }}" class="alert-link">Resend verification email</a>
  </div>
  {% elif error == 'registration_disabled' %}
  <div class="alert alert-error">Registrations are currently closed.</div>
  {% elif error == 'oauth_failed' %}
  <div class="alert alert-error">Google sign-in failed. Please try again.</div>
  {% elif error == 'oauth_email' %}
  <div class="alert alert-error">Could not retrieve a verified email from Google.</div>
  {% elif error == 'oauth_unavailable' %}
  <div class="alert alert-error">Google sign-in is not configured.</div>
  {% endif %}

  <form method="post" action="/auth/login" class="auth-form" id="loginForm">
    <div class="form-group">
      <label class="form-label" for="email">Email</label>
      <input type="email" id="email" name="email" class="form-input" required autofocus placeholder="you@example.com">
    </div>

    <!-- Email code section -->
    <div id="otpRequestSection">
      <button type="button" class="btn btn-outline btn-full" id="otpRequestBtn" onclick="requestOtp()">Sign in with email code</button>
    </div>
    <div id="otpCodeSection" style="display:none">
      <div id="otpAlert" class="alert alert-info">Code sent — check your inbox.</div>
      <div class="form-group" style="margin-top:8px">
        <label class="form-label" for="otpCodeInput">Enter code</label>
        <input type="text" id="otpCodeInput" name="otp_code" class="form-input" placeholder="123456" inputmode="numeric" autocomplete="one-time-code">
      </div>
      <button type="button" class="btn btn-primary btn-full" onclick="submitOtp()">Verify code</button>
      <button type="button" class="btn btn-outline btn-full" style="margin-top:6px" onclick="cancelOtp()">Use password instead</button>
    </div>

    <div class="auth-divider"><span>or</span></div>

    <div id="passwordSection">
      <div class="form-group">
        <label class="form-label" for="password">
          Password
          <a href="/auth/forgot-password" class="form-label-link">Forgot password?</a>
        </label>
        <input type="password" id="password" name="password" class="form-input" placeholder="••••••••">
      </div>
      <button type="submit" class="btn btn-primary btn-full">Sign in</button>
    </div>
  </form>

  <!-- Hidden form for OTP verify -->
  <form method="post" action="/auth/otp/verify" id="otpVerifyForm" style="display:none">
    <input type="hidden" name="email" id="otpVerifyEmail">
    <input type="hidden" name="code" id="otpVerifyCode">
  </form>

  <div class="auth-divider"><span>or</span></div>
  <a href="/auth/google" class="btn btn-google btn-full">
    <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
    Continue with Google
  </a>

  <p class="auth-footer">Don't have an account? <a href="/auth/register">Create one</a></p>
</div>
{% endblock %}

{% block scripts %}
<script>
function requestOtp() {
  const email = document.getElementById('email').value.trim();
  if (!email) {
    document.getElementById('email').focus();
    return;
  }
  const btn = document.getElementById('otpRequestBtn');
  btn.disabled = true;
  btn.textContent = 'Sending…';

  const body = new URLSearchParams({ email, ajax: '1' });
  fetch('/auth/otp/request', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body })
    .then(r => r.json())
    .then(data => {
      if (data.ok) {
        document.getElementById('otpRequestSection').style.display = 'none';
        document.getElementById('passwordSection').style.display = 'none';
        document.getElementById('otpCodeSection').style.display = '';
        document.getElementById('otpCodeInput').focus();
        const alert = document.getElementById('otpAlert');
        alert.className = 'alert alert-info';
        alert.textContent = 'Code sent — check your inbox.';
      } else if (data.error === 'rate_limit') {
        btn.disabled = false;
        btn.textContent = 'Sign in with email code';
        const alert = document.getElementById('otpAlert');
        document.getElementById('otpRequestSection').style.display = 'none';
        document.getElementById('otpCodeSection').style.display = '';
        alert.className = 'alert alert-warning';
        alert.textContent = 'Please wait ' + (data.wait || 'a few') + ' minute(s) before requesting another code.';
      } else {
        btn.disabled = false;
        btn.textContent = 'Sign in with email code';
        alert('Could not send code. Please check your email and try again.');
      }
    })
    .catch(() => {
      btn.disabled = false;
      btn.textContent = 'Sign in with email code';
    });
}

function submitOtp() {
  const email = document.getElementById('email').value.trim();
  const code = document.getElementById('otpCodeInput').value.trim();
  if (!code) { document.getElementById('otpCodeInput').focus(); return; }
  document.getElementById('otpVerifyEmail').value = email;
  document.getElementById('otpVerifyCode').value = code;
  document.getElementById('otpVerifyForm').submit();
}

function cancelOtp() {
  document.getElementById('otpRequestSection').style.display = '';
  document.getElementById('otpCodeSection').style.display = 'none';
  document.getElementById('passwordSection').style.display = '';
  const btn = document.getElementById('otpRequestBtn');
  btn.disabled = false;
  btn.textContent = 'Sign in with email code';
  document.getElementById('password').focus();
}

// Allow Enter key in code input to submit
document.addEventListener('DOMContentLoaded', function() {
  document.getElementById('otpCodeInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); submitOtp(); }
  });
});
</script>
{% endblock %}
