{% extends "layouts/base.njk" %}
{% block content %}
<div class="auth-card">
  <div class="auth-header">
    <h1 class="auth-title">{{ siteName }}</h1>
    <p class="auth-subtitle">Sign in with a one-time code</p>
  </div>

  {% if message == 'sent' %}<div class="alert alert-success">Code sent! Check your email.</div>{% endif %}
  {% if error == 'rate_limit' %}<div class="alert alert-warning">Please wait {{ wait }} minute(s) before requesting another code.</div>
  {% elif error == 'expired' %}<div class="alert alert-error">Your code expired. Request a new one.</div>
  {% elif error == 'invalid_code' %}<div class="alert alert-error">Incorrect code. Please try again.</div>
  {% elif error == 'too_many_attempts' %}<div class="alert alert-error">Too many attempts. Please request a new code.</div>
  {% elif error == 'no_code' %}<div class="alert alert-warning">No active code found. Request a new one.</div>
  {% elif error == 'blocked' %}<div class="alert alert-error">Access denied.</div>
  {% endif %}

  {% if not message %}
  <form method="post" action="/auth/otp/request" class="auth-form">
    <div class="form-group">
      <label class="form-label" for="email">Email address</label>
      <input type="email" id="email" name="email" value="{{ email or '' }}" class="form-input" required autofocus placeholder="you@example.com">
    </div>
    <button type="submit" class="btn btn-primary btn-full">Send code</button>
  </form>
  {% else %}
  <form method="post" action="/auth/otp/verify" class="auth-form">
    <input type="hidden" name="email" value="{{ email }}">
    <div class="form-group">
      <label class="form-label" for="code">6-digit code</label>
      <input type="text" id="code" name="code" class="form-input otp-input" maxlength="6" pattern="\d{6}" inputmode="numeric" required autofocus placeholder="000000">
    </div>
    <button type="submit" class="btn btn-primary btn-full">Verify code</button>
  </form>
  <form method="post" action="/auth/otp/request" class="mt-3" style="text-align:center">
    <input type="hidden" name="email" value="{{ email }}">
    <button type="submit" class="btn-link">Resend code</button>
  </form>
  {% endif %}

  <p class="auth-footer"><a href="/auth/login">← Sign in with password</a></p>
</div>
{% endblock %}
