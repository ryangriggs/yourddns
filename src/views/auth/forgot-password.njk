{% extends "layouts/base.njk" %}
{% block content %}
<div class="auth-card">
  <div class="auth-header">
    <h1 class="auth-title">Reset password</h1>
    <p class="auth-subtitle">Enter your email and we'll send a reset link.</p>
  </div>
  {% if message == 'sent' %}<div class="alert alert-success">If that email is registered, a reset link has been sent.</div>{% endif %}
  {% if error == 'missing' %}<div class="alert alert-error">Please enter your email.</div>{% endif %}
  <form method="post" action="/auth/forgot-password" class="auth-form">
    <div class="form-group">
      <label class="form-label" for="email">Email</label>
      <input type="email" id="email" name="email" class="form-input" required autofocus placeholder="you@example.com">
    </div>
    <button type="submit" class="btn btn-primary btn-full">Send reset link</button>
  </form>
  <p class="auth-footer"><a href="/auth/login">← Back to sign in</a></p>
</div>
{% endblock %}
