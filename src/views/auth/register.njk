{% extends "layouts/base.njk" %}
{% block content %}
<div class="auth-card">
  <div class="auth-header">
    <h1 class="auth-title">{{ siteName }}</h1>
    <p class="auth-subtitle">Create your account</p>
  </div>

  {% if error == 'missing' %}<div class="alert alert-error">All fields are required.</div>
  {% elif error == 'password_mismatch' %}<div class="alert alert-error">Passwords do not match.</div>
  {% elif error == 'password_short' %}<div class="alert alert-error">Password must be at least 8 characters.</div>
  {% elif error == 'invalid_email' %}<div class="alert alert-error">Please enter a valid email address.</div>
  {% elif error == 'email_taken' %}<div class="alert alert-error">An account with that email already exists.</div>
  {% elif error == 'blocked' %}<div class="alert alert-error">Access denied.</div>
  {% endif %}

  <form method="post" action="/auth/register" class="auth-form">
    <div class="form-group">
      <label class="form-label" for="email">Email</label>
      <input type="email" id="email" name="email" class="form-input" required autofocus placeholder="you@example.com">
    </div>
    <div class="form-group">
      <label class="form-label" for="password">Password</label>
      <input type="password" id="password" name="password" class="form-input" required placeholder="Min. 8 characters">
    </div>
    <div class="form-group">
      <label class="form-label" for="password2">Confirm Password</label>
      <input type="password" id="password2" name="password2" class="form-input" required placeholder="••••••••">
    </div>
    <button type="submit" class="btn btn-primary btn-full">Create account</button>
  </form>

  <div class="auth-divider"><span>or</span></div>
  <a href="/auth/google" class="btn btn-google btn-full">
    <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
    Continue with Google
  </a>

  <p class="auth-footer">Already have an account? <a href="/auth/login">Sign in</a></p>
</div>
{% endblock %}
