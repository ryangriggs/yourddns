{% extends "layouts/base.njk" %}
{% block content %}
<div class="auth-card">
  <div class="auth-header">
    <h1 class="auth-title">Set new password</h1>
  </div>
  {% if error == 'mismatch' %}<div class="alert alert-error">Passwords do not match.</div>
  {% elif error == 'short' %}<div class="alert alert-error">Password must be at least 8 characters.</div>
  {% endif %}
  <form method="post" action="/auth/reset-password" class="auth-form">
    <input type="hidden" name="token" value="{{ token }}">
    <div class="form-group">
      <label class="form-label" for="password">New password</label>
      <input type="password" id="password" name="password" class="form-input" required autofocus placeholder="Min. 8 characters">
    </div>
    <div class="form-group">
      <label class="form-label" for="password2">Confirm new password</label>
      <input type="password" id="password2" name="password2" class="form-input" required placeholder="••••••••">
    </div>
    <button type="submit" class="btn btn-primary btn-full">Update password</button>
  </form>
</div>
{% endblock %}
