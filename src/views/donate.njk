{% extends "layouts/landing.njk" %}
{% block content %}
<section class="landing-hero" style="padding-bottom:3rem">
  <div class="landing-container" style="max-width:680px">
    <h1 class="landing-hero-title" style="font-size:2rem">Support YourDDNS</h1>
    <p class="landing-hero-sub">YourDDNS is free, open-source software. There are no paid plans — just a tool built for developers who need reliable dynamic DNS.</p>
  </div>
</section>

<section class="landing-section">
  <div class="landing-container" style="max-width:680px">
    <div class="card mb-4">
      <div class="card-body" style="padding:2rem">
        <h2 style="margin:0 0 0.75rem;font-size:1.25rem">Why donate?</h2>
        <p style="color:#6b7280;line-height:1.7">Running a public DNS service has real costs: servers, bandwidth, and time. Your contribution — any amount — helps keep the service running, the domain zones active, and the project maintained.</p>
        <ul style="color:#6b7280;line-height:2;margin:1rem 0 0;padding-left:1.25rem">
          <li>Covers server and bandwidth costs</li>
          <li>Supports ongoing development and bug fixes</li>
          <li>Keeps the service free for everyone</li>
        </ul>
      </div>
    </div>

    {% if githubSponsorsUrl %}
    <div class="card mb-4">
      <div class="card-body" style="padding:2rem;text-align:center">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="#1f2328" style="margin-bottom:0.75rem"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        <h2 style="margin:0 0 0.5rem;font-size:1.25rem">Sponsor on GitHub</h2>
        <p style="color:#6b7280;margin-bottom:1.5rem">GitHub Sponsors passes 100% of your contribution directly to the developer — no fees.</p>
        <a href="{{ githubSponsorsUrl }}" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="font-size:1rem;padding:0.75rem 2rem">
          Sponsor on GitHub
        </a>
        <p style="color:#9ca3af;font-size:0.8rem;margin-top:1rem">Opens GitHub in a new tab. One-time or recurring options available.</p>
      </div>
    </div>
    {% endif %}

    {% if paypalUrl %}
    <div class="card mb-4">
      <div class="card-body" style="padding:2rem;text-align:center">
        <h2 style="margin:0 0 0.5rem;font-size:1.1rem;color:#6b7280;font-weight:500">Also via PayPal</h2>
        <a href="{{ paypalUrl }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="padding:0.6rem 1.5rem">
          Donate with PayPal
        </a>
      </div>
    </div>
    {% endif %}

    {% if not githubSponsorsUrl and not paypalUrl %}
    <div class="card mb-4">
      <div class="card-body" style="padding:2rem;text-align:center;color:#6b7280">
        <p>Donation links coming soon. In the meantime, starring the repo on GitHub is a great way to show support.</p>
      </div>
    </div>
    {% endif %}

    <div style="text-align:center;margin-top:1.5rem">
      <a href="/" style="color:#6b7280;font-size:0.9rem">← Back to home</a>
    </div>
  </div>
</section>
{% endblock %}
