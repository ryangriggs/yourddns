{% extends "layouts/base.njk" %}
{% set activePage = 'reports' %}
{% block head %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
{% endblock %}
{% block content %}
<div class="page-container">
  <div class="page-header">
    <h1 class="page-title">Reports</h1>
  </div>

  <div class="reports-layout">
    <div class="reports-sidebar">
      <div class="card">
        <div class="card-header"><h3 class="card-title">Select Records</h3></div>
        <div class="card-body p-0">
          {% if records | length == 0 %}
          <p class="p-4 text-muted">No records yet.</p>
          {% else %}
          <ul class="record-list">
            {% for record in records %}
            <li class="record-list-item">
              <label class="record-checkbox-label">
                <input type="checkbox" class="record-check" value="{{ record.id }}" onchange="updateChart()">
                <span class="record-fqdn">{{ record.subdomain }}<span class="text-muted">.{{ record.zone_domain }}</span></span>
              </label>
            </li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="reports-main">
      <div class="card mb-4">
        <div class="card-body">
          <div class="reports-controls">
            <div class="form-group mb-0">
              <label class="form-label">Date range</label>
              <div class="date-range-inputs">
                <input type="text" id="fromDate" class="form-input form-input-sm" placeholder="From">
                <span class="text-muted">—</span>
                <input type="text" id="toDate" class="form-input form-input-sm" placeholder="To">
              </div>
            </div>
            <button class="btn btn-outline btn-sm" onclick="updateChart()">Apply</button>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-body">
          <div id="chartEmpty" class="chart-empty">
            <p class="text-muted">Select one or more records to view their DNS hit history.</p>
          </div>
          <div id="chartWrap" style="display:none; position:relative; height:320px">
            <canvas id="hitsChart"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
const COLORS = ['#2563eb','#16a34a','#d97706','#dc2626','#7c3aed','#0891b2','#be185d','#65a30d'];
let chart = null;
let colorMap = {};
let colorIdx = 0;

const today = new Date();
const weekAgo = new Date(today - 7*24*60*60*1000);
const fmt = d => d.toISOString().split('T')[0];

flatpickr('#fromDate', { defaultDate: weekAgo, onChange: () => updateChart() });
flatpickr('#toDate',   { defaultDate: today,   onChange: () => updateChart() });

function getColor(id) {
  if (!colorMap[id]) colorMap[id] = COLORS[colorIdx++ % COLORS.length];
  return colorMap[id];
}

function fillDates(from, to, data) {
  const map = {};
  for (const d of data) map[d.day] = d.count;
  const result = [], labels = [];
  const cur = new Date(from);
  const end = new Date(to);
  while (cur <= end) {
    const k = fmt(cur);
    labels.push(k);
    result.push(map[k] || 0);
    cur.setDate(cur.getDate() + 1);
  }
  return { labels, values: result };
}

async function updateChart() {
  const checked = [...document.querySelectorAll('.record-check:checked')].map(c => c.value);
  const from = document.getElementById('fromDate').value || fmt(weekAgo);
  const to   = document.getElementById('toDate').value   || fmt(today);

  if (!checked.length) {
    document.getElementById('chartEmpty').style.display = '';
    document.getElementById('chartWrap').style.display = 'none';
    if (chart) { chart.destroy(); chart = null; }
    return;
  }

  const params = checked.map(id => `records[]=${id}`).join('&');
  const res = await fetch(`/reports/data?${params}&from=${from}&to=${to}`);
  const { datasets } = await res.json();

  document.getElementById('chartEmpty').style.display = 'none';
  document.getElementById('chartWrap').style.display = '';

  const allLabels = [];
  const cur2 = new Date(from), end2 = new Date(to);
  while (cur2 <= end2) { allLabels.push(fmt(cur2)); cur2.setDate(cur2.getDate()+1); }

  const chartDatasets = datasets.map(ds => {
    const color = getColor(ds.id);
    const { values } = fillDates(from, to, ds.data);
    return { label: ds.label, data: values, borderColor: color, backgroundColor: color+'22', fill: true, tension: 0.3, pointRadius: 3 };
  });

  if (chart) chart.destroy();
  chart = new Chart(document.getElementById('hitsChart'), {
    type: 'line',
    data: { labels: allLabels, datasets: chartDatasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { position: 'top' }, tooltip: { callbacks: { title: t => t[0].label } } },
      scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } }, x: { grid: { display: false } } }
    }
  });
}
</script>
{% endblock %}
