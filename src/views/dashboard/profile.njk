{% extends "layouts/base.njk" %}
{% set activePage = 'profile' %}
{% block content %}
<div class="page-container page-narrow">
  <div class="page-header">
    <h1 class="page-title">Profile</h1>
  </div>

  {% if flash %}<div class="alert alert-{{ flash.type }} mb-4">{{ flash.message }}</div>{% endif %}

  <div class="card mb-4">
    <div class="card-header"><h2 class="card-title">Account</h2></div>
    <div class="card-body">
      <div class="info-row"><span class="info-label">Email</span><span>{{ user.email }}</span></div>
      <div class="info-row"><span class="info-label">Plan</span>
        <span class="badge badge-blue">{{ user.tier_display_name }}</span>
      </div>
      <div class="info-row"><span class="info-label">Member since</span><span class="text-muted">{{ user.created_at | date }}</span></div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h2 class="card-title">Change Plan</h2></div>
    <div class="card-body">
      <div class="plan-grid">
        {% for tier in tiers %}
        <div class="plan-option {% if tier.id == user.tier_id %}plan-option-current{% endif %}">
          <div class="plan-option-name">{{ tier.display_name }}</div>
          <div class="plan-option-price">
            {% if tier.price_monthly == 0 %}Free
            {% else %}${{ (tier.price_monthly / 100) | round(2) }}/mo{% endif %}
          </div>
          <ul class="plan-option-features">
            <li>{{ tier.max_entries }} records</li>
            <li>{{ tier.min_ttl }}s min TTL</li>
            <li>{{ tier.max_resolutions_per_hour }} resolutions/hr</li>
            <li>{{ tier.history_days }} days history</li>
            {% if tier.max_custom_domains > 0 %}<li>{{ tier.max_custom_domains }} custom domain{% if tier.max_custom_domains != 1 %}s{% endif %}</li>{% endif %}
          </ul>
          {% if tier.id == user.tier_id %}
          <span class="btn btn-sm btn-outline w-full" style="cursor:default;opacity:0.6">Current plan</span>
          {% else %}
          <form method="post" action="/dashboard/profile/change-plan">
            <input type="hidden" name="tier_id" value="{{ tier.id }}">
            <button type="submit" class="btn btn-sm btn-primary w-full">Switch to this plan</button>
          </form>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% if googleEnabled %}
  <div class="card mb-4">
    <div class="card-header"><h2 class="card-title">Connected Accounts</h2></div>
    <div class="card-body">
      <div class="info-row">
        <span class="info-label">
          <svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="vertical-align:-3px;margin-right:6px"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Google
        </span>
        {% if 'google' in linkedProviders %}
        <span style="display:flex;align-items:center;gap:12px">
          <span class="badge badge-green">Connected</span>
          {% if user.password_hash %}
          <form method="post" action="/dashboard/profile/unlink-google" onsubmit="return confirm('Unlink your Google account?')">
            <button type="submit" class="btn btn-xs btn-outline">Unlink</button>
          </form>
          {% endif %}
        </span>
        {% else %}
        <a href="/auth/google" class="btn btn-xs btn-outline">Connect</a>
        {% endif %}
      </div>
    </div>
  </div>
  {% endif %}

  <div class="card">
    {% if user.password_hash %}
    <div class="card-header"><h2 class="card-title">Change Password</h2></div>
    <div class="card-body">
      <form method="post" action="/dashboard/profile/change-password">
        <div class="form-group">
          <label class="form-label" for="current_password">Current password</label>
          <input type="password" id="current_password" name="current_password" class="form-input" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="new_password">New password</label>
          <input type="password" id="new_password" name="new_password" class="form-input" required minlength="8">
        </div>
        <div class="form-group">
          <label class="form-label" for="new_password2">Confirm new password</label>
          <input type="password" id="new_password2" name="new_password2" class="form-input" required>
        </div>
        <button type="submit" class="btn btn-primary">Update password</button>
      </form>
    </div>
    {% else %}
    <div class="card-header"><h2 class="card-title">Set a Password</h2></div>
    <div class="card-body">
      <p class="text-muted mb-3" style="font-size:0.875rem">Add a password to your account so you can also sign in with email and password.</p>
      <form method="post" action="/dashboard/profile/set-password">
        <div class="form-group">
          <label class="form-label" for="new_password">Password</label>
          <input type="password" id="new_password" name="new_password" class="form-input" required minlength="8" placeholder="Min. 8 characters">
        </div>
        <div class="form-group">
          <label class="form-label" for="new_password2">Confirm password</label>
          <input type="password" id="new_password2" name="new_password2" class="form-input" required>
        </div>
        <button type="submit" class="btn btn-primary">Set password</button>
      </form>
    </div>
    {% endif %}
  </div>
</div>
{% endblock %}
