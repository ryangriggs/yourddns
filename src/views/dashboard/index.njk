{% extends "layouts/base.njk" %}
{% set activePage = 'dashboard' %}
{% block content %}
<div class="page-container">
  <div class="page-header">
    <div>
      <h1 class="page-title">DNS Records</h1>
      <p class="page-subtitle">{{ records | length }} / {{ tier.max_entries }} records used</p>
    </div>
    <button class="btn btn-primary" onclick="openModal('createModal')">+ New Record</button>
  </div>

  {% if flash %}
  <div class="alert alert-{{ flash.type }} mb-4">{{ flash.message }}</div>
  {% endif %}

  {% if newPat %}
  <div class="alert alert-warning pat-reveal" id="patReveal">
    <div class="pat-reveal-header">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      <strong>Save your API key — it will not be shown again</strong>
    </div>
    <p class="pat-record-name">Record: <strong>{{ newPat.subdomain }}.{{ newPat.zone }}</strong></p>
    <div class="pat-code-wrap">
      <code class="pat-code" id="patCode">{{ newPat.pat }}</code>
      <button class="btn btn-xs btn-outline" onclick="copyPat()">Copy</button>
    </div>
  </div>
  {% endif %}

  {% if records | length == 0 %}
  <div class="empty-state">
    <div class="empty-icon">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15v-4H7l5-8v4h4l-5 8z"/></svg>
    </div>
    <h3>No records yet</h3>
    <p>Create your first dynamic DNS record to get started.</p>
    <button class="btn btn-primary" onclick="openModal('createModal')">+ New Record</button>
  </div>
  {% else %}
  <div class="table-card">
    <table class="table">
      <thead>
        <tr>
          <th>Subdomain</th>
          <th>IP / IPv6</th>
          <th>TTL</th>
          <th>Hits</th>
          <th>Last Update</th>
          <th>Created</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for record in records %}
        <tr class="{% if not record.is_enabled %}row-disabled{% endif %}">
          <td>
            <div class="subdomain-cell">
              <span class="subdomain-name">{{ record.subdomain }}<span class="subdomain-zone">.{{ record.zone_domain }}</span></span>
            </div>
          </td>
          <td class="mono">
            {{ record.ip_address or '—' }}
            {% if record.ip6_address %}<br><span class="text-muted" style="font-size:0.82em">{{ record.ip6_address }}</span>{% endif %}
          </td>
          <td class="mono">{{ record.ttl }}s</td>
          <td>{{ record.hit_count }}</td>
          <td class="text-muted">{{ record.last_update_received_at | date('relative') }}</td>
          <td class="text-muted">{{ record.created_at | date }}</td>
          <td>
            <span class="badge {% if record.is_enabled %}badge-green{% else %}badge-gray{% endif %}">
              {{ 'Active' if record.is_enabled else 'Disabled' }}
            </span>
          </td>
          <td class="actions-cell">
            <div class="dropdown-trigger" data-id="{{ record.id }}">
              <button class="icon-btn" title="More options" onclick="toggleRowMenu({{ record.id }})">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
              </button>
              <div class="row-dropdown" id="rowMenu{{ record.id }}">
                <button class="dropdown-item" onclick="openSetup({{ record.id }})">Instructions</button>
                <button class="dropdown-item" onclick="openEditRecord({{ record.id }})">Edit</button>
                <div class="dropdown-divider"></div>
                <form method="post" action="/dashboard/records/{{ record.id }}/toggle">
                  <button type="submit" class="dropdown-item">{{ 'Disable' if record.is_enabled else 'Enable' }}</button>
                </form>
<form method="post" action="/dashboard/records/{{ record.id }}/regenerate-pat" onsubmit="return confirm('Regenerate API key? The existing key will stop working immediately.')">
                  <button type="submit" class="dropdown-item">Regenerate API key</button>
                </form>
                <div class="dropdown-divider"></div>
                <form method="post" action="/dashboard/records/{{ record.id }}/delete" onsubmit="return confirm('Delete this record? This cannot be undone.')">
                  <button type="submit" class="dropdown-item text-danger">Delete</button>
                </form>
              </div>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</div>

<!-- Create Record Modal -->
<div class="modal-overlay" id="createModal">
  <div class="modal">
    <div class="modal-header">
      <h2 class="modal-title">New DNS Record</h2>
      <button class="modal-close" onclick="closeModal('createModal')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form method="post" action="/dashboard/records" class="modal-body">
      <div class="form-group">
        <label class="form-label" for="subdomain">Subdomain</label>
        <input type="text" id="subdomain" name="subdomain" class="form-input" required
          placeholder="myhome" pattern="[a-zA-Z0-9-]+" minlength="{{ tier.min_subdomain_length }}"
          title="Letters, numbers, and hyphens only.">
        <p class="form-hint" id="subdomainHint">Min {{ tier.min_subdomain_length }} characters. Letters, numbers, hyphens only.</p>
      </div>
      <div class="form-group">
        <label class="form-label" for="zone_id">Zone</label>
        <select id="zone_id" name="zone_id" class="form-select" required onchange="updateSubdomainHint()">
          {% for zone in zones %}
          <option value="{{ zone.id }}" data-custom="{{ 'true' if zone.user_id else 'false' }}">{{ zone.domain }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="form-group">
        <label class="form-label" for="ip">IPv4 Address <span class="text-muted">(optional)</span></label>
        <input type="text" id="ip" name="ip" class="form-input" value="{{ clientIp if clientIp and '.' in clientIp else '' }}"
          placeholder="Leave blank to set on first update">
        <p class="form-hint">Defaults to your current IP if IPv4. Clear to leave unset.</p>
      </div>
      <div class="form-group">
        <label class="form-label" for="ip6">IPv6 Address <span class="text-muted">(optional)</span></label>
        <input type="text" id="ip6" name="ip6" class="form-input" value="{{ clientIp if clientIp and ':' in clientIp else '' }}"
          placeholder="Leave blank to set on first update">
        <p class="form-hint">Defaults to your current IP if IPv6. Clear to leave unset.</p>
      </div>
      <div class="form-group">
        <label class="form-label" for="ttl">TTL (seconds)</label>
        <input type="number" id="ttl" name="ttl" class="form-input" value="{{ tier.min_ttl }}" min="{{ tier.min_ttl }}" step="60">
        <p class="form-hint">Minimum {{ tier.min_ttl }}s on your plan.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('createModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Create record</button>
      </div>
    </form>
  </div>
</div>

<!-- Setup Instructions Modal -->
<div class="modal-overlay" id="setupModal">
  <div class="modal modal-lg">
    <div class="modal-header">
      <h2 class="modal-title">Setup Instructions</h2>
      <button class="modal-close" onclick="closeModal('setupModal')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body" id="setupContent">
      <div class="loading-spin"></div>
    </div>
  </div>
</div>

<!-- Edit Record Modal -->
<div class="modal-overlay" id="editModal">
  <div class="modal">
    <div class="modal-header">
      <h2 class="modal-title">Edit Record</h2>
      <button class="modal-close" onclick="closeModal('editModal')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form method="post" id="editForm" class="modal-body">
      <div class="form-group">
        <label class="form-label">Subdomain</label>
        <p id="editSubdomain" class="form-hint" style="font-family:monospace;font-size:1em;padding:6px 0"></p>
      </div>
      <div class="form-group">
        <label class="form-label" for="editIp">IPv4 Address <span class="text-muted">(optional)</span></label>
        <input type="text" id="editIp" name="ip" class="form-input" placeholder="Leave blank to clear">
      </div>
      <div class="form-group">
        <label class="form-label" for="editIp6">IPv6 Address <span class="text-muted">(optional)</span></label>
        <input type="text" id="editIp6" name="ip6" class="form-input" placeholder="Leave blank to clear">
      </div>
      <div class="form-group">
        <label class="form-label" for="editTtl">TTL (seconds)</label>
        <input type="number" id="editTtl" name="ttl" class="form-input" min="{{ tier.min_ttl }}" step="60">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('editModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

{% endblock %}

{% block scripts %}
<script>
const recordsData = {
  {% for record in records %}
  {{ record.id }}: {ip: {{ record.ip_address | json }}, ip6: {{ record.ip6_address | json }}, ttl: {{ record.ttl }}, fqdn: {{ (record.subdomain + '.' + record.zone_domain) | json }} }{% if not loop.last %},{% endif %}
  {% endfor %}
};
function openEditRecord(id) {
  const r = recordsData[id];
  if (!r) return;
  document.getElementById('editForm').action = '/dashboard/records/' + id + '/edit';
  document.getElementById('editSubdomain').textContent = r.fqdn;
  document.getElementById('editIp').value = r.ip || '';
  document.getElementById('editIp6').value = r.ip6 || '';
  document.getElementById('editTtl').value = r.ttl;
  openModal('editModal');
}
function updateSubdomainHint() {
  const sel = document.getElementById('zone_id');
  const opt = sel.options[sel.selectedIndex];
  const input = document.getElementById('subdomain');
  const hint = document.getElementById('subdomainHint');
  const isCustom = opt && opt.dataset.custom === 'true';
  if (isCustom) {
    input.removeAttribute('minlength');
    hint.textContent = 'Letters, numbers, hyphens only. No minimum length for your own domains.';
  } else {
    input.setAttribute('minlength', '{{ tier.min_subdomain_length }}');
    hint.textContent = 'Min {{ tier.min_subdomain_length }} characters. Letters, numbers, hyphens only.';
  }
}
function showTab(name) {
  document.querySelectorAll('.setup-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.setup-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  event.target.classList.add('active');
}
function copyCode(btn) {
  const pre = btn.nextElementSibling;
  navigator.clipboard.writeText(pre.textContent).then(() => {
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
  });
}
function openSetup(id) {
  openModal('setupModal');
  document.getElementById('setupContent').innerHTML = '<div class="loading-spin"></div>';
  fetch('/dashboard/records/' + id + '/setup')
    .then(r => r.text())
    .then(html => { document.getElementById('setupContent').innerHTML = html; });
}
function copyPat() {
  const code = document.getElementById('patCode').textContent;
  navigator.clipboard.writeText(code).then(() => {
    const btn = document.querySelector('.pat-code-wrap .btn');
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
  });
}
</script>
{% endblock %}
