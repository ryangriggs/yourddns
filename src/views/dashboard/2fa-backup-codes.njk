{% extends "layouts/base.njk" %}
{% set activePage = 'profile' %}
{% block content %}
<div class="page-container page-narrow">
  <div class="page-header">
    <h1 class="page-title">Two-Factor Authentication Enabled</h1>
  </div>

  <div class="alert alert-success mb-4">Two-factor authentication has been enabled on your account.</div>

  <div class="card mb-4">
    <div class="card-header">
      <h2 class="card-title">Save Your Backup Codes</h2>
    </div>
    <div class="card-body">
      <p class="text-muted mb-3" style="font-size:0.875rem">
        Store these backup codes somewhere safe. Each code can be used <strong>once</strong> to sign in
        if you lose access to your authenticator app. They will not be shown again.
      </p>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:0.5rem;margin:1rem 0;max-width:380px">
        {% for code in backupCodes %}
        <div style="font-family:monospace;font-size:0.9rem;padding:0.5rem 0.75rem;background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:6px;text-align:center;letter-spacing:0.05em">
          {{ code }}
        </div>
        {% endfor %}
      </div>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1rem">
        <button onclick="copyAll()" class="btn btn-outline btn-sm">Copy all codes</button>
        <button onclick="printCodes()" class="btn btn-outline btn-sm">Print</button>
      </div>
    </div>
  </div>

  <a href="/dashboard/profile" class="btn btn-primary">I've saved my codes — continue</a>
</div>
{% endblock %}

{% block scripts %}
<script>
const codes = {{ backupCodes | dump | safe }};
function copyAll() {
  navigator.clipboard.writeText(codes.join('\n')).then(() => {
    const btn = event.target;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy all codes', 2000);
  });
}
function printCodes() {
  const w = window.open('', '_blank');
  w.document.write('<pre style="font-size:14px;font-family:monospace">' +
    'Backup codes for your account:\n\n' + codes.join('\n') + '\n\nKeep these somewhere safe.</pre>');
  w.document.close();
  w.print();
}
</script>
{% endblock %}
