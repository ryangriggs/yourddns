<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — {{ siteName }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/main.css">
</head>
<body class="landing-body">
  <header class="landing-header">
    <div class="landing-header-inner">
      <a href="/" class="logo">{{ siteName }}</a>
      <div class="landing-header-actions">
        <a href="/auth/login" class="btn btn-outline btn-sm">Sign In</a>
        {% if registrationEnabled %}
        <a href="/auth/register" class="btn btn-primary btn-sm">Create Account</a>
        {% endif %}
      </div>
    </div>
  </header>

  {% block content %}{% endblock %}

  <footer class="landing-footer">
    <div class="landing-container">
      © {{ siteName }} &nbsp;·&nbsp;
      <a href="/terms">Terms &amp; Conditions</a> &nbsp;·&nbsp;
      <a href="/donate">Donate</a> &nbsp;·&nbsp;
      <a href="https://github.com/ryangriggs/yourddns" target="_blank" rel="noopener">GitHub</a> &nbsp;·&nbsp;
      v{{ appVersion }}
    </div>
  </footer>
</body>
</html>
