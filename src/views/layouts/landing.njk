<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — {{ siteName }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/main.css">
  <link rel="icon" href="/favicon.svg?v={{ faviconVersion }}" type="image/svg+xml">
</head>
<body class="landing-body">
  <header class="landing-header">
    <div class="landing-header-inner">
      <a href="/" class="logo">{{ siteName }}</a>
      <div class="landing-header-actions">
        {% if user %}
        <div class="user-menu" id="userMenuBtn">
          <span class="user-email">{{ user.email }}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          <div class="user-dropdown" id="userDropdown">
            <a href="/dashboard" class="dropdown-item">Dashboard</a>
            <div class="dropdown-divider"></div>
            <a href="/dashboard/profile" class="dropdown-item">Profile</a>
            <a href="/dashboard/api-keys" class="dropdown-item">API Keys</a>
            <a href="/dashboard/api-keys#api-docs" class="dropdown-item">API Documentation</a>
            {% if user.is_admin %}
            <a href="/admin" class="dropdown-item">Admin Panel</a>
            {% endif %}
            <div class="dropdown-divider"></div>
            <form method="post" action="/auth/logout">
              <button type="submit" class="dropdown-item w-full text-left">Sign out</button>
            </form>
          </div>
        </div>
        {% else %}
        <a href="/auth/login" class="btn btn-outline btn-sm">Sign In</a>
        {% if registrationEnabled %}
        <a href="/auth/register" class="btn btn-primary btn-sm">Sign Up</a>
        {% endif %}
        {% endif %}
      </div>
    </div>
  </header>

  {% block content %}{% endblock %}

  <footer class="landing-footer">
    <div class="landing-container">
      © {{ siteName }} &nbsp;·&nbsp;
      <a href="/terms">Terms &amp; Conditions</a> &nbsp;·&nbsp;
      <a href="/donate">Donate</a> &nbsp;·&nbsp;
      <a href="https://github.com/ryangriggs/yourddns" target="_blank" rel="noopener">GitHub</a> &nbsp;·&nbsp;
      v{{ appVersion }}
    </div>
  </footer>
  <script src="/public/js/main.js"></script>
</body>
</html>
