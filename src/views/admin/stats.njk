{% extends "layouts/admin.njk" %}
{% set activePage = 'stats' %}
{% block head %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
{% endblock %}
{% block content %}
<div class="page-container">
  <div class="page-header"><h1 class="page-title">Stats</h1></div>

  {% macro sortLink(col, label) %}
    {% set nextDir = 'asc' if (sort == col and dir == 'desc') else 'desc' %}
    {% set arrow = ' ↑' if (sort == col and dir == 'asc') else (' ↓' if (sort == col and dir == 'desc') else '') %}
    <a href="?sort={{ col }}&dir={{ nextDir }}&per={{ per }}&page=1" style="color:inherit;text-decoration:none;white-space:nowrap">{{ label }}{{ arrow }}</a>
  {% endmacro %}

  <div class="reports-layout">
    <div class="reports-sidebar">
      <div class="card">
        <div class="card-header"><h3 class="card-title">Select Records</h3></div>
        <div class="card-body p-0">
          {% if total == 0 %}
          <p class="p-4 text-muted">No records yet.</p>
          {% else %}
          <ul class="record-list">
            {% for record in records %}
            <li class="record-list-item">
              <label class="record-checkbox-label">
                <input type="checkbox" class="record-check" value="{{ record.id }}" onchange="updateChart()">
                <span>
                  <span class="record-fqdn">{{ record.subdomain }}<span class="text-muted">.{{ record.zone_domain }}</span></span><br>
                  <span class="text-xs text-muted">{{ record.user_email }}</span>
                </span>
              </label>
            </li>
            {% endfor %}
          </ul>
          {% if totalPages > 1 %}
          <div style="padding:8px 12px;border-top:1px solid var(--border-color);display:flex;gap:6px;align-items:center;font-size:0.8125rem">
            {% if page > 1 %}<a href="?sort={{ sort }}&dir={{ dir }}&per={{ per }}&page={{ page - 1 }}" class="btn btn-xs btn-outline">←</a>{% endif %}
            <span class="text-muted">{{ page }}/{{ totalPages }}</span>
            {% if page < totalPages %}<a href="?sort={{ sort }}&dir={{ dir }}&per={{ per }}&page={{ page + 1 }}" class="btn btn-xs btn-outline">→</a>{% endif %}
          </div>
          {% endif %}
          {% endif %}
        </div>
      </div>
    </div>

    <div class="reports-main">
      <div class="card mb-4">
        <div class="card-body">
          <div class="reports-controls">
            <div class="form-group mb-0">
              <label class="form-label">Date range</label>
              <div class="date-range-inputs">
                <input type="text" id="fromDate" class="form-input form-input-sm" placeholder="From">
                <span class="text-muted">—</span>
                <input type="text" id="toDate" class="form-input form-input-sm" placeholder="To">
              </div>
            </div>
            <button class="btn btn-outline btn-sm" onclick="updateChart()">Apply</button>
          </div>
        </div>
      </div>
      <div class="card mb-4">
        <div class="card-body">
          <div id="chartEmpty" class="chart-empty"><p class="text-muted">Select records to view DNS hit history.</p></div>
          <div id="chartWrap" style="display:none; position:relative; height:320px"><canvas id="hitsChart"></canvas></div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Records <span class="text-muted" style="font-size:0.8125rem;font-weight:400">{{ total }} total</span></h2>
          <span class="text-muted" style="font-size:0.8125rem">Per page:
            {% for n in [10, 50, 100, 500] %}
            <a href="?sort={{ sort }}&dir={{ dir }}&per={{ n }}&page=1" class="{% if per == n %}font-bold{% endif %}" style="margin:0 3px">{{ n }}</a>
            {% endfor %}
          </span>
        </div>
        <table class="table">
          <thead>
            <tr>
              <th>{{ sortLink('subdomain', 'Subdomain') }}</th>
              <th>{{ sortLink('zone', 'Zone') }}</th>
              <th>{{ sortLink('user', 'User') }}</th>
              <th>{{ sortLink('ip', 'IP') }}</th>
              <th>{{ sortLink('hits', 'Hits') }}</th>
              <th>{{ sortLink('updated', 'Last Updated') }}</th>
            </tr>
          </thead>
          <tbody>
            {% for record in records %}
            <tr>
              <td class="mono">{{ record.subdomain }}</td>
              <td class="text-muted">{{ record.zone_domain }}</td>
              <td class="text-muted">{{ record.user_email }}</td>
              <td class="mono">
                {{ record.ip_address or '—' }}
                {% if record.ip6_address %}<br><span style="font-size:0.8em;color:#6b7280">{{ record.ip6_address }}</span>{% endif %}
              </td>
              <td>{{ record.hit_count }}</td>
              <td class="text-muted">{{ record.last_update_received_at | date('relative') }}</td>
            </tr>
            {% endfor %}
            {% if records | length == 0 %}
            <tr><td colspan="6" class="text-muted" style="text-align:center;padding:2rem">No records.</td></tr>
            {% endif %}
          </tbody>
        </table>
        {% if totalPages > 1 %}
        <div class="pagination" style="padding:12px 16px">
          {% if page > 1 %}<a href="?sort={{ sort }}&dir={{ dir }}&per={{ per }}&page={{ page - 1 }}" class="btn btn-sm btn-outline">← Prev</a>{% endif %}
          <span class="text-muted" style="font-size:0.875rem">Page {{ page }} of {{ totalPages }}</span>
          {% if page < totalPages %}<a href="?sort={{ sort }}&dir={{ dir }}&per={{ per }}&page={{ page + 1 }}" class="btn btn-sm btn-outline">Next →</a>{% endif %}
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
{% block scripts %}
<script>
const COLORS = ['#2563eb','#16a34a','#d97706','#dc2626','#7c3aed','#0891b2','#be185d','#65a30d'];
let chart = null, colorMap = {}, colorIdx = 0;
const today = new Date(), weekAgo = new Date(today - 7*24*60*60*1000);
const fmt = d => d.toISOString().split('T')[0];
flatpickr('#fromDate', { defaultDate: weekAgo });
flatpickr('#toDate',   { defaultDate: today });
function getColor(id) { if (!colorMap[id]) colorMap[id] = COLORS[colorIdx++ % COLORS.length]; return colorMap[id]; }
function fillDates(from, to, data) {
  const map = {}; for (const d of data) map[d.day] = d.count;
  const result = [], labels = [], cur = new Date(from), end = new Date(to);
  while (cur <= end) { const k = fmt(cur); labels.push(k); result.push(map[k]||0); cur.setDate(cur.getDate()+1); }
  return { labels, values: result };
}
async function updateChart() {
  const checked = [...document.querySelectorAll('.record-check:checked')].map(c => c.value);
  const from = document.getElementById('fromDate').value || fmt(weekAgo);
  const to = document.getElementById('toDate').value || fmt(today);
  if (!checked.length) { document.getElementById('chartEmpty').style.display=''; document.getElementById('chartWrap').style.display='none'; if(chart){chart.destroy();chart=null;} return; }
  const params = checked.map(id=>`records=${id}`).join('&');
  const res = await fetch(`/admin/stats/data?${params}&from=${from}&to=${to}`);
  const { datasets } = await res.json();
  document.getElementById('chartEmpty').style.display='none';
  document.getElementById('chartWrap').style.display='';
  const allLabels=[]; const cur2=new Date(from),end2=new Date(to);
  while(cur2<=end2){allLabels.push(fmt(cur2));cur2.setDate(cur2.getDate()+1);}
  const cd = datasets.map(ds=>{ const color=getColor(ds.id); const {values}=fillDates(from,to,ds.data); return {label:ds.label,data:values,borderColor:color,backgroundColor:color+'22',fill:true,tension:0.3,pointRadius:3}; });
  if(chart)chart.destroy();
  chart=new Chart(document.getElementById('hitsChart'),{type:'line',data:{labels:allLabels,datasets:cd},options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},plugins:{legend:{position:'top'}},scales:{y:{beginAtZero:true,ticks:{stepSize:1}},x:{grid:{display:false}}}}});
}
</script>
{% endblock %}
