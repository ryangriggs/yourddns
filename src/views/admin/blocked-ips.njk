{% extends "layouts/admin.njk" %}
{% set activePage = 'blocked-ips' %}
{% block content %}
<div class="page-container">
  <div class="page-header">
    <h1 class="page-title">Blocked IPs <span class="text-muted" style="font-size:0.875rem;font-weight:400">{{ total }} total</span></h1>
    <button class="btn btn-primary" onclick="openModal('addIpModal')">+ Block IP</button>
  </div>

  {% if flash %}<div class="alert alert-{{ flash.type }} mb-4">{{ flash.message }}</div>{% endif %}

  {% macro sortLink(col, label) %}
    {% set nextDir = 'asc' if (sort == col and dir == 'desc') else 'desc' %}
    {% set arrow = ' ↑' if (sort == col and dir == 'asc') else (' ↓' if (sort == col and dir == 'desc') else '') %}
    <a href="?sort={{ col }}&dir={{ nextDir }}&per={{ per }}&page=1" style="color:inherit;text-decoration:none;white-space:nowrap">{{ label }}{{ arrow }}</a>
  {% endmacro %}

  <div class="filter-bar mb-4">
    <span class="text-muted" style="font-size:0.8125rem">Per page:
      {% for n in [10, 50, 100, 500] %}
      <a href="?sort={{ sort }}&dir={{ dir }}&per={{ n }}&page=1" class="{% if per == n %}font-bold{% endif %}" style="margin:0 3px">{{ n }}</a>
      {% endfor %}
    </span>
  </div>

  <div class="table-card">
    {% if total == 0 %}
    <div class="empty-state"><p class="text-muted">No blocked IPs.</p></div>
    {% else %}
    <table class="table">
      <thead>
        <tr>
          <th>{{ sortLink('ip', 'IP Address') }}</th>
          <th>{{ sortLink('reason', 'Reason') }}</th>
          <th>{{ sortLink('blocked_by', 'Blocked by') }}</th>
          <th>{{ sortLink('date', 'Date') }}</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for ip in ips %}
        <tr>
          <td class="mono">{{ ip.ip_address }}</td>
          <td class="text-muted">{{ ip.reason or '—' }}</td>
          <td class="text-muted">{{ ip.created_by_email or 'system' }}</td>
          <td class="text-muted">{{ ip.created_at | date }}</td>
          <td>
            <form method="post" action="/admin/blocked-ips/{{ ip.id }}/delete">
              <button type="submit" class="btn btn-xs btn-danger">Unblock</button>
            </form>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
  </div>

  {% if totalPages > 1 %}
  <div class="pagination mt-4">
    {% if page > 1 %}<a href="?sort={{ sort }}&dir={{ dir }}&per={{ per }}&page={{ page - 1 }}" class="btn btn-sm btn-outline">← Prev</a>{% endif %}
    <span class="text-muted" style="font-size:0.875rem">Page {{ page }} of {{ totalPages }}</span>
    {% if page < totalPages %}<a href="?sort={{ sort }}&dir={{ dir }}&per={{ per }}&page={{ page + 1 }}" class="btn btn-sm btn-outline">Next →</a>{% endif %}
  </div>
  {% endif %}
</div>

<div class="modal-overlay" id="addIpModal">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h2 class="modal-title">Block IP Address</h2>
      <button class="modal-close" onclick="closeModal('addIpModal')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form method="post" action="/admin/blocked-ips" class="modal-body">
      <div class="form-group">
        <label class="form-label">IP Address</label>
        <input type="text" name="ip_address" class="form-input" required placeholder="1.2.3.4">
      </div>
      <div class="form-group">
        <label class="form-label">Reason <span class="text-muted">(optional)</span></label>
        <input type="text" name="reason" class="form-input" placeholder="Spam, abuse, etc.">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('addIpModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Block</button>
      </div>
    </form>
  </div>
</div>
{% endblock %}
