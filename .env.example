# Application
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
SESSION_SECRET=change-this-to-a-random-64-char-hex-string-in-production
PAT_HMAC_SECRET=change-this-to-another-random-secret-string

# Site (overridable in Admin Settings UI too)
SITE_NAME=YourDDNS
SITE_DOMAIN=yourddns.com
SITE_URL=https://yourddns.com
SUPPORT_EMAIL=support@yourddns.com

# Database
DB_PATH=./data/yourddns.db

# DNS Server (container-internal port; map to host port via docker-compose)
DNS_PORT=53
DNS_HOST=0.0.0.0

# Admin bootstrap (used only on first startup to create admin account)
ADMIN_EMAIL=admin@yourddns.com
ADMIN_PASSWORD=changeme123

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourddns.com

# Caddy (ACME / Let's Encrypt)
CADDY_EMAIL=admin@yourddns.com

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
