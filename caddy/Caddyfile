{
    email {$CADDY_EMAIL}

    # Allow on-demand TLS for custom user domains.
    # Caddy asks the app before provisioning any cert it hasn't seen before.
    on_demand_tls {
        ask http://app:3000/internal/caddy-ask
        interval 2m
        burst 5
    }
}

# Main site
{$SITE_DOMAIN} {
    reverse_proxy app:3000
}

# www → apex redirect
www.{$SITE_DOMAIN} {
    redir https://{$SITE_DOMAIN}{uri} permanent
}

# Catch-all: on-demand TLS for validated custom user domains.
# Caddy provisions a cert automatically when a new domain first connects.
:443 {
    tls {
        on_demand
    }
    reverse_proxy app:3000
}

# HTTP catch-all — Caddy handles the HTTP→HTTPS upgrade automatically for
# named sites above; this covers any remaining plain-HTTP hits.
:80 {
    reverse_proxy app:3000
}
